<h2 class="mb-3">Buyer Payments</h2>

<table class="table table-bordered table-striped">
  <thead class="table-dark">
    <tr>
      <th>Buyer</th>
      <th>Plan</th>
      <th>Amount</th>
      <th>Transaction ID</th>
      <th>Status</th>
      <th>Payment Date</th>
    </tr>
  </thead>
  <tbody>
    <% @payments.each do |payment| %>
      <tr>
        <td><%= payment.buyer.name %></td>
        <td><%= payment.plan.name %></td>
        <td><%= number_to_currency(payment.amount) %></td>
        <td><%= payment.transaction_id %></td>
        
        <td>
          <% status_class = case payment.status
            when "success" then "badge bg-success"
            when "failed" then "badge bg-danger"
            when "pending" then "badge bg-warning"
          end %>
          <span class="<%= status_class %>"><%= payment.status.capitalize %></span>
        </td>

        <td><%= payment.created_at.strftime("%B %d, %Y - %I:%M %p") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
