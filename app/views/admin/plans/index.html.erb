<div class="container mt-5">
  <h1 class="mb-4">Plans</h1>
  <%= link_to 'Create New Plan', new_admin_plan_path, class: "btn btn-primary mb-3" %>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Monthly Fee</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @plans.each do |plan| %>
        <tr>
          <td><%= plan.name %></td>
          <td>$<%= plan.monthly_fee %></td>
          <td>
            <%= link_to 'Edit', edit_admin_plan_path(plan), class: "btn btn-warning btn-sm" %>
            <%= link_to 'Delete', admin_plan_path(plan), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this plan?" }, class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
