<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Plans</h2>
    <%= link_to "Add New Plan", new_admin_plan_path, class: "btn btn-primary" %>
  </div>

  <table class="table table-striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Monthly Fee</th>
        <th>Features</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @plans.each do |plan| %>
        <tr>
          <td><%= plan.name %></td>
          <td><%= number_to_currency(plan.monthly_fee, unit: "$") %></td>
          <td>
            <% plan.features.each do |feature| %>
              <span class="badge bg-secondary"><%= feature.name %>($<%= feature.unit_price %>)</span>
            <% end %>
          </td>
          <td>
            <%= link_to "Edit", edit_admin_plan_path(plan), class: "btn btn-warning btn-sm" %>
            <%= link_to "Delete", admin_plan_path(plan), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>