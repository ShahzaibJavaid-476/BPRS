<div class="form-group">
  <%= f.label :name %>
  <%= f.text_field :name, class: "form-control" %>
</div>

<div class="form-group">
  <%= f.label :features, "Select Features" %><br>
  <%= f.collection_check_boxes :feature_ids, Feature.all, :id, :name %>
</div>

<%= f.submit "Save Plan", class: "btn btn-primary" %>