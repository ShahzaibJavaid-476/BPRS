<div class="container mt-5">
  <h1 class="mb-4">Edit Plan</h1>

  <%= form_with model: @plan, url: admin_plan_path(@plan), local: true, method: :patch, class: "card p-4 shadow" do |f| %>
    <div class="mb-3">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>

    <div class="mb-3">
      <%= f.label :monthly_fee, class: "form-label" %>
      <%= f.number_field :monthly_fee, class: "form-control", step: "0.01", required: true %>
    </div>

    <%= f.submit "Update Plan", class: "btn btn-primary" %><br>
    <%= link_to 'Cancel', admin_plans_path, class: "btn btn-secondary ms-2" %>
  <% end %>
</div>
