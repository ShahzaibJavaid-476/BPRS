<h1>Subscriptions</h1>
<%= link_to 'New Subscription', new_admin_subscription_path, class: "btn btn-primary" %>

<table class="table mt-3">
  <thead>
    <tr>
      <th>Buyer</th>
      <th>Plan</th>
      <th>Billing Day</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @subscriptions.each do |subscription| %>
      <tr>
        <td><%= subscription.buyer.name %></td>
        <td><%= subscription.plan.name %></td>
        <td><%= subscription.billing_day %></td>
        <td><%= subscription.active ? 'Active' : 'Inactive' %></td>
        <td>
          <%= link_to 'Edit', edit_admin_subscription_path(subscription), class: "btn btn-warning btn-sm" %>
          <%= link_to 'Delete', admin_subscription_path(subscription),
                      data: {turbo_method: :delete, turbo_confirm: "Are you sure?" }, 
                      class: "btn btn-danger btn-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
