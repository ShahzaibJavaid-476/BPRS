<%= form_with(model: @subscription, url: admin_subscriptions_path, local: true, class: "card p-4 shadow") do |f| %>
  <div class="mb-3">
    <%= f.label :buyer_id, "Buyer", class: "form-label" %>
    <%= f.collection_select :buyer_id, User.where(role: "buyer"), :id, :name, { prompt: "Select a buyer" }, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :plan_id, "Plan", class: "form-label" %>
    <%= f.collection_select :plan_id, Plan.all, :id, :name, { prompt: "Select a plan" }, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :billing_day, "Billing Day (1-30)", class: "form-label" %>
    <%= f.number_field :billing_day, in: 1..30, class: "form-control" %>
  </div>

  <div class="form-check">
    <%= f.check_box :active, class: "form-check-input" %>
    <%= f.label :active, "Active", class: "form-check-label" %>
  </div>

  <div class="mt-3">
    <%= f.submit "Save Subscription", class: "btn btn-success" %>
  </div>
<% end %>
