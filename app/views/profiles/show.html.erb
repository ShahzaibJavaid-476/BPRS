<div class="container mt-5">
  <h1>My Profile</h1>
  <div class="row">
    <div class="col-md-3">
      <% if current_user.profile_photo.attached? %>
        <%= image_tag current_user.profile_photo.variant(resize: "150x150"), class: "rounded-circle" %>
      <% else %>
        <%= image_tag "default_profile.png", class: "rounded-circle", alt: "Default Profile", size: "150x150" %>
      <% end %>
    </div>
    <div class="col-md-9">
      <p><strong>Name:</strong> <%= current_user.name %></p>
      <p><strong>Email:</strong> <%= current_user.email %></p>
      <%= link_to "Edit Profile", edit_profile_path, class: "btn btn-primary" %>
    </div>
  </div>
</div>