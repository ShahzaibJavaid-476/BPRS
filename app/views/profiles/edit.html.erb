<div class="container mt-5">
  <h1>Edit Profile</h1>
  
  <%= form_with model: current_user, url: profile_path, local: true, method: :patch do |f| %>
    <div class="form-group">
      <%= f.label :name %>
      <%= f.text_field :name, class: "form-control" %>
    </div>
    
    <div class="form-group">
      <%= f.label :email %>
      <%= f.email_field :email, class: "form-control" %>
    </div>
    
    <div class="form-group">
      <%= f.label :profile_photo, "Profile Picture" %>
      <%= f.file_field :profile_photo, class: "form-control" %>
      <% if current_user.profile_photo.attached? %>
        <p>Current Photo:</p>
        <%= image_tag current_user.profile_photo.variant(resize: "100x100"), class: "rounded-circle" %>
      <% end %>
    </div>
    
    <%= f.submit "Update Profile", class: "btn btn-success" %>
  <% end %>
  
  <%= link_to "Back to Profile", profile_path, class: "btn btn-secondary mt-3" %>
</div>