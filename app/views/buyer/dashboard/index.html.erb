<div class="container mt-5">
  <div class="card shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center">
      <h4 class="text-primary font-weight-bold">Welcome, <%= current_user.name %></h4>
      <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-danger btn-sm" %>
    </div>
  </div>
  <div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Dashboard</h1>
  <%= render "shared/profile_icon" %>
</div>


  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary">Available Plans</h2>
  </div>

  <div class="row">
    <% @plans.each do |plan| %>
      <div class="col-md-4 mb-4">
        <div class="card shadow-lg h-100">
          <div class="card-body">
            <h4 class="card-title text-center text-uppercase"><%= plan.name %></h4>
            <p class="card-text text-center text-muted"><strong>Monthly Fee:</strong> <%= number_to_currency(plan.monthly_fee) %></p>
            
            <div class="card-footer text-muted">
              <p><strong>Features:</strong></p>
              <ul class="list-unstyled">
                <% plan.features.each do |feature| %>
                  <li><%= feature.name %> - <%= number_to_currency(feature.unit_price) %></li>
                <% end %>
              </ul>
              <div class="d-flex justify-content-center mt-3">
                <%= link_to "View Subscriptions", buyer_plan_path(plan), class: "btn btn-primary btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
