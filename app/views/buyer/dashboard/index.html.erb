<div class="container mt-5">
  <div class="card shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center">
      <%= render "shared/profile_icon" %>
      <h4 class="text-primary font-weight-bold">Welcome, <%= current_user.name %></h4>
      <%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-danger btn-sm" %>
    </div>
  </div>
  <% if current_user.subscriptions.where(active: true).present? %>
  <h2 class="mb-3">Your Active Subscriptions</h2>
  <table class="table table-bordered table-striped">
    <thead class="table-dark">
      <tr>
        <th>Plan</th>
        <th>Features</th>
        <th>Start Date</th>
        <th>Next Billing Day</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% current_user.subscriptions.where(active: true).each do |subscription| %>
        <tr>
          <td><strong><%= subscription.plan.name %></strong></td>

          <td>
            <ul class="list-unstyled">
              <% subscription.plan.features.each do |feature| %>
                <li>✅ <%= feature.name %> (<%= number_to_currency(feature.unit_price) %>)
                <div class="btn-group ms-2">
                    <%= button_to "Use 2 Units", buyer_usages_path(feature_id: feature.id, subscription_id: subscription.id, buyer_id: current_user.id, units_used: 2), 
                        method: :post, class: "btn btn-primary btn-sm" %>

                    <%= button_to "Use 5 Units", buyer_usages_path(feature_id: feature.id, subscription_id: subscription.id, buyer_id: current_user.id, units_used: 5), 
                        method: :post, class: "btn btn-warning btn-sm" %>

                    <%= button_to "Use 7 Units", buyer_usages_path(feature_id: feature.id, subscription_id: subscription.id, buyer_id: current_user.id, units_used: 7), 
                        method: :post, class: "btn btn-danger btn-sm" %>
                  </div>
                </li>
              <% end %>
            </ul>
          </td>

          <td><%= subscription.created_at.strftime("%B %d, %Y") %></td>

          <td><%= Date.today.next_month.change(day: subscription.billing_day).strftime("%B %d, %Y") %></td>

          <td>
            <%= link_to "Cancel", 
                buyer_plan_subscription_path(subscription.plan, subscription),
                data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to cancel this subscription?" }, 
                class: "btn btn-danger btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <h2>You have no active subscriptions</h2>
<% end %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary">Available Plans</h2>
  </div>

  <div class="row">
  <% @plans.each do |plan| %>
    <div class="col-md-4 mb-4">
      <div class="card shadow-lg h-100">
        <div class="card-body">
          <h4 class="card-title text-center text-uppercase"><%= plan.name %></h4>
          <p class="card-text text-center text-muted">
            <strong>Monthly Fee:</strong> <%= number_to_currency(plan.monthly_fee) %>
          </p>
          
          <div class="card-footer text-muted">
            <p><strong>Features:</strong></p>
            <ul class="list-unstyled">
              <% plan.features.each do |feature| %>
                <li><%= feature.name %> - <%= number_to_currency(feature.unit_price) %></li>
              <% end %>
            </ul>

            <% subscription = current_user.subscriptions.find_by(plan_id: plan.id) %>
            <div class="d-flex justify-content-center mt-3">
              <% if subscription&.active? %>
                <%= button_to "Unsubscribe", buyer_plan_subscription_path(plan, subscription), method: :delete, class: "btn btn-danger btn-sm" %>
              <% else %>
                <%= button_to "Subscribe", checkout_buyer_plan_subscriptions_path(plan_id: plan.id), method: :get, class: "btn btn-success btn-sm", data: { turbo: false } %>
              <% end %>
            </div>

          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<h2 class="mt-5">Your Feature Usage History</h2>
  <table class="table table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Plan</th>
        <th>Feature</th>
        <th>Units Used</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% current_user.usages.includes(:feature, :subscription).order(created_at: :desc).each do |usage| %>
        <tr>
          <td><%= usage.subscription.plan.name %></td>
          <td><%= usage.feature.name %></td>
          <td><strong><%= usage.units_used %></strong> units</td>
          <td><%= usage.created_at.strftime("%B %d, %Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>