<div class="container mt-5">
  <!-- Plan Name and Monthly Fee -->
  <div class="card shadow-sm mb-4">
    <div class="card-body text-center">
      <h2 class="text-primary font-weight-bold"><%= @plan.name %></h2>
      <p class="text-muted">Monthly Fee: <%= number_to_currency(@plan.monthly_fee) %></p>
    </div>
  </div>

  <!-- Subscription Types -->
  <div class="card shadow-lg">
    <div class="card-body">
      <h3 class="text-center text-primary mb-4">Choose a Subscription Type</h3>

      <!-- Subscription Options -->
      <div class="row text-center">
        <% @subscription_types.each do |type| %>
          <div class="col-md-4 mb-3">
            <div class="card shadow-lg">
              <div class="card-body">
                <h4 class="card-title"><%= type.capitalize %></h4>
                <p class="card-text">Select this subscription to get started with <%= @plan.name %>.</p>
                <%= link_to "Subscribe", new_buyer_plan_subscription_path(@plan, subscription_type: type), class: "btn btn-success btn-lg" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
